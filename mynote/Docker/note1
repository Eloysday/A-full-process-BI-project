#  清理错误编译垃圾
rm -f *.so *.build *.pyi
# 编译代码
cd /code/app/api/v1
for file in *.py; do python -m nuitka --module "$file" --remove-output; done
或者指定服务器的python版本进行编译和dockerfile保持一致注意可能要升级python
cd /code/app/api/v1
for file in *.py; do python3.10 -m nuitka --module "$file" --remove-output; done
注意切换文件夹和某些下层文件夹
cd /code/app/services
cd /code/app/services/storage
cd /code/app/models
cd /code/app/schemas
删除残留文件注意切换文件夹
cd /code
find app/api/v1 -name "*.py" ! -name "__init__.py" -delete
find app/services -name "*.py" ! -name "__init__.py" -delete
find app/models -name "*.py" ! -name "__init__.py" -delete
find app/schemas -name "*.py" ! -name "__init__.py" -delete
# 进入项目目录不分本地or服务器
cd D:\lumos_fastumi_manager

# 镜像之前给脚本加执行权限
=================================重要：chmod +x docker_start_prod.sh===========================
# 查看所有镜像
docker images
# 删除所有镜像
docker rmi -f $(docker images -q)
# 删除指定旧镜像
docker rmi -f localhost/lumos-fastumi:v1

# 查看正在运行的容器
docker ps
# 查看所有容器（包括停止的）
docker ps -a
# 停止所有容器
docker stop $(docker ps -aq)
#删除指定容器
docker rm -f lumos
# 删除所有容器
docker rm -f $(docker ps -aq)

清理命令	危险程度	数据风险
docker system prune	🟢 安全	不会删卷和正在使用的镜像
docker system prune -a	🟡 中等	可能删你需要但未运行的镜像（需重新下载）
docker system prune -a --volumes	🔴 高危	会删除卷中的数据（数据库文件等）

# 重新构建镜像
docker-compose -f compose.dev.yaml build --no-cache
podman-compose -f compose.yaml build --no-cache
podman build -t lumos_fastumi_manager:latest .
# 启动镜像
podman-compose -f compose.yaml up -d
docker-compose -f compose.yaml up -d


# 导出镜像为  lumos-fastumi-v1.tar 包镜像名称是localhost/lumos-fastumi:v1
docker save -o lumos-fastumi-v1.tar localhost/lumos-fastumi:v1
# 传输镜像
scp lumos-fastumi-v1.tar root@内网IP:/root/code
# 导入镜像
podman load -i lumos_fastumi_manager.tar

